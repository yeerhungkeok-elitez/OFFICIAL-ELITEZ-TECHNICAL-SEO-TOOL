# ─────────────────────────────────────────────────────────────────────────────
# Elitez Technical SEO Doctor — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values you need.
# All variables are optional — the tool works fully without any of them
# using localStorage and console logging as defaults.
#
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (cloud lead storage) ─────────────────────────────────────────────
# Leave blank to use localStorage only (default).
# See docs/supabase-leads-setup.md for setup instructions.
# ⚠️ NEVER put the service_role key here — use the anon/public key only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Admin password ────────────────────────────────────────────────────────────
# If set, the /admin/leads page requires this password before showing leads.
# Leave blank to allow access without a password (fine for local development).
# This is stored in sessionStorage — expires when the browser tab is closed.
NEXT_PUBLIC_ADMIN_PASSWORD=

# ── Email / lead notifications ────────────────────────────────────────────────
# Zapier webhook: receives a JSON POST for each new lead submission.
# Leave blank to log new leads to the browser console only.
# See docs/email-notification-setup.md for all provider options.
# ⚠️ This URL is visible in browser source — do not use for sensitive API calls.
NEXT_PUBLIC_ZAPIER_WEBHOOK_URL=

# ── (Future / server-side only) ───────────────────────────────────────────────
# These are NOT NEXT_PUBLIC_ — they must only be used in API routes / server actions.
# Uncomment and fill in once you add a server-side notification API route.
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# NOTIFY_EMAIL_TO=hello@elitez.asia
# NOTIFY_EMAIL_FROM=noreply@yourdomain.com
